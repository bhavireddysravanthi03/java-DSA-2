package JavaClass;
import java.util.Scanner;

public class Factorial {

	public static void main(String[] args) {
		Scanner sc=new Scanner(System.in);
		System.out.print("Enter a Number:");
		int a=sc.nextInt();		
		int fact=1;
		int i=1;
		while(i<=a) {
			fact=fact*i;
			i++;
		}
		System.out.print("fact of a:"+fact);
		sc.close();
		
	}
	
}
